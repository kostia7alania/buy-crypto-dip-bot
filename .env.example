# LOCAL DEV environment (copy to .env, gitignored).
# Production uses a separate file on the server — see .env.production.example
# and docs/13_VPS_DEPLOYMENT_RUNBOOK.md. Dev and prod credentials never mix.

# PostgreSQL (docker compose up -d starts a local instance with these creds)
POSTGRES_CONNECTION_STRING=postgresql://postgres:local_password@localhost:5432/dipbot

# Trading API
PORT=8787
API_URL=http://localhost:8787
# Shared secret between web BFF / bot and the API. Leave empty locally;
# REQUIRED on a VPS — without it the API is open to the internet.
API_KEY=

# Telegram
TELEGRAM_BOT_TOKEN=
# Fallback chat for alerts. Send /start to the bot to see your chat id.
TELEGRAM_CHAT_ID=

# Risk
ALLOWLIST_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT
