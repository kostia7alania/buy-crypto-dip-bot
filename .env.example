NODE_ENV=development

# Safety defaults
LIVE_TRADING_ENABLED=false
DRY_RUN_DEFAULT=true
ALLOWLIST_SYMBOLS=BTCUSDT
MAX_DAILY_SPEND_USDT=20
MAX_WEEKLY_SPEND_USDT=100
MAX_ORDER_SIZE_USDT=50
MIN_ORDER_SIZE_USDT=5
COOLDOWN_MINUTES=360

# Public market data is allowed without keys.
BYBIT_USE_TESTNET=true
BYBIT_API_KEY=
BYBIT_API_SECRET=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# API / Web
API_BASE_URL=http://localhost:8787
NUXT_PUBLIC_API_BASE_URL=http://localhost:8787
