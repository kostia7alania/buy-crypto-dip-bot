{
  "name": "@buy-crypto-dip-bot/db",
  "private": true,
  "type": "module",
  "exports": {
    "types": "./src/index.ts",
    "import": "./dist/index.js",
    "default": "./dist/index.js"
  },
  "scripts": {
    "build": "tsdown src/index.ts --format esm --out-dir dist --no-dts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "drizzle-orm": "catalog:",
    "pg": "catalog:",
    "@buy-crypto-dip-bot/shared-types": "workspace:*"
  },
  "devDependencies": {
    "typescript": "catalog:",
    "vitest": "catalog:",
    "tsdown": "catalog:",
    "@types/node": "catalog:",
    "drizzle-kit": "catalog:",
    "@types/pg": "^8.11.10"
  }
}
