# Production environment — lives ONLY on the server at
# /opt/buy-crypto-dip-bot/.env (chmod 600, owner deploy).
# scripts/vps-bootstrap.sh generates the secrets automatically.
# Never commit a filled copy; never reuse dev values in prod.

# Generated by bootstrap (openssl rand)
POSTGRES_PASSWORD=
API_KEY=
SESSION_SECRET=

# Fill manually
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Bot username (without @) for the dashboard's Telegram Login button.
# Requires /setdomain in BotFather for the site domain.
NUXT_PUBLIC_TELEGRAM_BOT_USERNAME=

ALLOWLIST_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT

# GA4 Measurement ID for the web app (e.g. G-XXXXXXXXXX). Leave unset to
# fall back to the placeholder in apps/web/nuxt.config.ts (analytics won't
# report real data until this is set).
NUXT_PUBLIC_GA_ID=

# Note: POSTGRES_CONNECTION_STRING, API_URL and ports are composed inside
# docker-compose.prod.yml from these values — do not set them here.
